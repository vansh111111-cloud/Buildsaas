<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Verify OTP | YourSaaS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="card">
    <h2>Email Verification</h2>
    <p>Enter the 6-digit OTP sent to your email.</p>

    <% if(error){ %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="POST" action="/verify-otp">
      <input 
        type="text" 
        name="otp" 
        placeholder="Enter 6-digit OTP" 
        maxlength="6" 
        pattern="\d{6}" 
        required
      >

      <button type="submit" class="btn-filled">Verify OTP</button>
    </form>

    <p class="resend-text">
      Didn't receive OTP? <a href="/resend-otp">Resend</a>
    </p>
  </div>
</body>
</html>
