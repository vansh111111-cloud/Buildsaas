<!DOCTYPE html>
<html>

<head>

<title>Workspace</title>

<link rel="stylesheet" href="/css/workspace-header.css">
<link rel="stylesheet" href="/css/workspace-sidebar.css">
<link rel="stylesheet" href="/css/workspace.css">
<link rel="stylesheet" href="/css/workspace-dashboard.css">

</head>

<body data-project-id="<%= project._id %>">

<!-- LOADER -->

<div id="loader">

<div class="loader-card">

<div class="loader-logo">
Build<span>SaaS</span>
</div>

<div class="loader-bar">
<div class="loader-progress"></div>
</div>

<p class="loader-text">Preparing your workspace...</p>

</div>

</div>

<!-- WORKSPACE -->

<div id="workspace" style="display:none;">

<%- include("partials/workspace-header") %>

<div class="editor-container">

<%- include("partials/workspace-sidebar") %>

<main class="editor-main">

<!-- DASHBOARD -->

<div class="workspace-dashboard">

<div class="dashboard-header">

<h2><%= project.name || "Project Dashboard" %></h2>

<div class="project-meta">

<span class="role-badge">
Role: <%= projectRole %>
</span>

<span class="plan-badge">
Plan: Free
</span>

</div>

</div>

<div class="dashboard-grid">

<!-- INVITE CARD -->

<button id="inviteBtn" class="invite-btn">Invite</button>

<div id="inviteModal" class="modal">
  <div class="modal-content">
    <span id="closeInvite" class="close">&times;</span>

    <h3>Invite Member</h3>

    <input type="email" placeholder="Enter Email" id="inviteEmail">

    <button id="sendInvite">Send Invite</button>
  </div>
</div>

<!-- GETTING STARTED VIDEO -->

<div class="dashboard-card">

<h3>Getting Started</h3>

<iframe
width="100%"
height="200"
src="https://www.youtube.com/embed/hX1BmWrc9Fg?si=B37QBLebw_blPnS4"
frameborder="0"
allowfullscreen>
</iframe>

</div>

<!-- RECENT ACTIVITY -->

<div class="dashboard-card">

<h3>Recent Activity</h3>

<ul class="activity-list">

<li>Project created</li>
<li>Plugin installed</li>
<li>File edited</li>

</ul>

</div>

<!-- TIPS -->

<div class="dashboard-card">

<h3>Tips</h3>

<ul class="tips-list">

<li>Install plugins to extend your builder</li>
<li>Invite teammates to collaborate</li>
<li>Create pages from templates</li>

</ul>

</div>

</div>

</div>

<!-- TABS -->

<div id="files" class="tab-panel">
<h2>Files</h2>
<p>Your project files will appear here.</p>
</div>

<div id="environment" class="tab-panel" style="display:none;">
<h2>Environment</h2>
<p>.env variables will appear here</p>
</div>

<div id="templates" class="tab-panel" style="display:none;">
<h2>Templates</h2>
</div>

<div id="plugins" class="tab-panel" style="display:none;">
<h2>Plugins</h2>
</div>

<div id="settings" class="tab-panel" style="display:none;">
<h2>Settings</h2>
</div>

</main>

</div>

</div>

<script src="/js/workspace.js"></script>



</body>
</html>
